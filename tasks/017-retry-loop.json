{
  "id": "017-retry-loop",
  "goal": "Trigger next improvement step when decision is retry_improvement.",
  "scope": [
    "read comparison decision",
    "if retry_improvement, generate a new improvement task"
  ],
  "non_scope": [
    "no automatic Claude execution",
    "no commit",
    "no merge",
    "no external API"
  ],
  "checks": [
    {
      "type": "command",
      "run": "node scripts/trigger-next-step.js /tmp/comparison-decision.json",
      "expect": "exit_code_0"
    }
  ]
}
